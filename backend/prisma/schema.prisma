generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AppSetting {
  id         String   @id @default(uuid())
  systemName String  @default("CryoMap")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("app_settings")
}
